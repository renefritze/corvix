{
    "name": "corvix-frontend",
    "private": true,
    "version": "0.1.0",
    "type": "module",
    "scripts": {
        "dev": "vite",
        "build": "npm run gen:types && svelte-check --tsconfig ./tsconfig.json && vite build",
        "check": "svelte-check --tsconfig ./tsconfig.json",
        "preview": "vite preview",
        "test": "vitest",
        "test:watch": "vitest watch",
        "test:coverage": "vitest run --coverage",
        "gen:types": "openapi-typescript ./openapi.json --output ./src/api-types.gen.ts"
    },
    "dependencies": {
        "@fontsource-variable/inter": "^5.2.5",
        "@lucide/svelte": "^0.545.0",
        "svelte": "^5.35.0"
    },
    "devDependencies": {
        "@sveltejs/vite-plugin-svelte": "^6.0.0",
        "@tailwindcss/vite": "^4.1.0",
        "@testing-library/jest-dom": "^6.9.1",
        "@testing-library/svelte": "^5.2.4",
        "@testing-library/user-event": "^14.6.1",
        "@vitest/coverage-v8": "^4.1.10",
        "jsdom": "^29.1.1",
        "openapi-typescript": "^7.5.0",
        "svelte-check": "^4.3.0",
        "tailwindcss": "^4.1.0",
        "terser": "^5.49.0",
        "typescript": "^5.9.2",
        "vite": "^7.0.0",
        "vitest": "^4.1.10"
    },
    "overrides": {
        "openapi-typescript": {
            "typescript": "$typescript"
        }
    }
}
