{
    "name": "corvix-frontend",
    "private": true,
    "version": "0.1.0",
    "scripts": {
        "dev": "vite",
        "build": "npm run gen:types && tsc --noEmit && vite build",
        "preview": "vite preview",
        "test": "vitest",
        "test:watch": "vitest watch",
        "test:coverage": "vitest run --coverage",
        "gen:types": "openapi-typescript ./openapi.json --output ./src/api-types.gen.ts"
    },
    "dependencies": {
        "preact": "^10.29.3",
        "preact-router": "^4.1.2"
    },
    "devDependencies": {
        "@preact/preset-vite": "^2.9.3",
        "@testing-library/jest-dom": "^6.9.1",
        "@testing-library/preact": "^3.2.4",
        "@testing-library/user-event": "^14.6.1",
        "@vitest/coverage-v8": "^4.1.9",
        "jsdom": "^29.1.1",
        "openapi-typescript": "^7.5.0",
        "terser": "^5.48.0",
        "typescript": "^6.0.3",
        "vite": "^8.1.2",
        "vitest": "^4.1.4"
    },
    "overrides": {
        "openapi-typescript": {
            "typescript": "$typescript"
        }
    }
}
