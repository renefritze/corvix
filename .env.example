GITHUB_TOKEN=ghp_replace_me

# Fernet symmetric key for encrypting GitHub tokens stored in the database.
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# Docker secret file alternative: TOKEN_ENCRYPTION_KEY_FILE=/run/secrets/token_encryption_key
TOKEN_ENCRYPTION_KEY=replace_with_generated_key

# --- Observability (all optional) ---
# Structured logging level and format (json|console).
# CORVIX_LOG_LEVEL=INFO
# CORVIX_LOG_FORMAT=json
# Enable OpenTelemetry tracing (requires the `otel` extra). Off by default.
# CORVIX_OTEL_ENABLED=true
# OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4318
# OTEL_SERVICE_NAME=corvix
